###############################################################################
# DEM (plane-swe-agents) — full configuration reference.
#
# This is the complete, annotated list of every variable the conductor can seed
# from the environment. It mirrors what you'd get from exporting a fully
# configured setup (admin console → Config → Export .env), so it's handy for
# IaC/Pulumi provisioning or restoring a known-good config.
#
# You do NOT need this file to get started: `make setup` uses .env.minimal.example
# (just the two mandatory fields below) and you configure the rest in the wizard.
#
# The DB is the source of truth. Everything under OPTIONAL is a FIRST-BOOT SEED
# only: on first startup these env vars are imported into the DB, after which the
# DB wins and you manage config via the admin console. Set RESEED_FROM_ENV=true
# to re-import env over the DB on the next boot (for IaC-driven rotation).
#
# The values below are DUMMY DEV DEFAULTS: they let the stack boot and mark the
# wizard "complete", but they are NOT valid credentials — connection tests and
# real Plane/GitHub/Claude calls will fail until you replace them. NEVER use
# these in production; regenerate DEM_SECRET_KEY and supply real secrets there.
###############################################################################

# ── MANDATORY (env-only; needed before the DB is reachable) ──────────────────
# DEM_SECRET_KEY — root of trust for encrypting stored secrets; CANNOT live in
#   the DB it decrypts. Throwaway DEV key below; regenerate for real deployments:
#     python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# DATABASE_URL — job/state + config store. SQLite by default; Postgres for
#   servers: postgresql+asyncpg://user:pass@db/dem
DEM_SECRET_KEY=KZuEczTWuN0bKeiUYVY6q8JDT6mMSYwX48d3g8RRqms=
DATABASE_URL=sqlite+aiosqlite:////data/conductor.db


#══════════════════════════════════════════════════════════════════════════════
#  OPTIONAL — first-boot seed for everything the setup wizard manages.
#  Grouped below in the wizard's step order.
#══════════════════════════════════════════════════════════════════════════════

# ── Bootstrap options (env-only; not shown in the wizard) ────────────────────
# RESEED_FROM_ENV — re-import env/seed-file over the DB on boot (default false =
#   seed-once). CONFIG_SEED_FILE — optional YAML seed file, merged with env on
#   first boot. TARGETS_FILE — project->repo mapping seeded on first boot (DB
#   wins after). CONDUCTOR_HOST / CONDUCTOR_PORT — bind address for the API.
RESEED_FROM_ENV=false
# CONFIG_SEED_FILE=config.seed.yml
TARGETS_FILE=targets.yml
CONDUCTOR_HOST=0.0.0.0
CONDUCTOR_PORT=8420

# ── Claude ───────────────────────────────────────────────────────────────────
# Set EXACTLY ONE credential — CLAUDE_CODE_OAUTH_TOKEN (Pro/Max subscription; run
# `claude setup-token` and paste) OR ANTHROPIC_API_KEY (metered, teams/prod).
# Both or neither is reported as an incomplete-config issue, not a hard failure.
# CLAUDE_MODEL_* — the Claude Code --model value used for each pipeline role.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxx
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL_ENGINEER=claude-sonnet-4-6
CLAUDE_MODEL_PLANNER=claude-sonnet-4-6
CLAUDE_MODEL_REVIEWER=claude-haiku-4-5
CLAUDE_MODEL_QA=claude-haiku-4-5

# ── Plane ────────────────────────────────────────────────────────────────────
# PLANE_BASE_URL — self-hosted instance base (Cloud is https://api.plane.so).
# PLANE_WORKSPACE_SLUG — the segment in your Plane URL. PLANE_API_KEY — Personal
# Access Token (Profile Settings → Personal Access Tokens). PLANE_WEBHOOK_SECRET
# — secret Plane generates for the webhook pointed at <public-url>/webhooks/plane
# (verifies X-Plane-Signature). PLANE_EPIC_SIGNAL — how an epic is recognized:
# label | type | parentless (CE has no Epic type; use a label named "epic").
# PLANE_AGENTS_ENABLED / PLANE_BOT_TOKEN — Plane Agents beta (native bot
# comments); default false uses REST comments via the PAT.
PLANE_BASE_URL=https://plane.eroizzy.com
PLANE_WORKSPACE_SLUG=dem
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxx
PLANE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
PLANE_EPIC_SIGNAL=label
PLANE_AGENTS_ENABLED=false
# PLANE_BOT_TOKEN=bot_xxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────────────────────────────
# GITHUB_TOKEN — one machine-account fine-grained PAT that can reach every target
# repo (scopes: Contents:rw, Pull requests:rw, Metadata:r). Which Plane project
# builds into which repo — and each repo's base branch — lives in targets.yml.
# GITHUB_EVENT_MODE — webhook (public URL) or poll. GITHUB_POLL_INTERVAL_SECONDS —
# poll cadence when mode=poll. The webhook secret is project-scoped (set per project
# in the wizard / targets.yml), not a global env var.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
GITHUB_EVENT_MODE=webhook
GITHUB_POLL_INTERVAL_SECONDS=60

# ── Notifications ────────────────────────────────────────────────────────────
# NOTIFY_MODE — ntfy | slack | webhook | none. Set the matching URL for the
# chosen mode (required when mode is not "none"); leave the others unset.
NOTIFY_MODE=none
# NOTIFY_NTFY_URL=https://ntfy.sh/my-secret-topic
# NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx
# NOTIFY_WEBHOOK_URL=https://example.com/hook

# ── Advanced ─────────────────────────────────────────────────────────────────
# CONDUCTOR_PUBLIC_URL — public base URL; Plane/GitHub webhook targets are built
# from it. MAX_CONCURRENT_AGENTS — simultaneous agent containers (subscription +
# RAM limits). AGENT_TIMEOUT_MINUTES — hard per-run timeout before docker kill.
# AGENT_IMAGE / AGENT_MEMORY_LIMIT / AGENT_CPU_LIMIT — agent container image and
# resource caps. DOCKER_HOST — socket path or socket-proxy URL for the dispatcher.
# OTEL_* — point at your existing collector; keep observability external.
CONDUCTOR_PUBLIC_URL=https://dem.eroizzy.com
MAX_CONCURRENT_AGENTS=1
AGENT_TIMEOUT_MINUTES=30
AGENT_IMAGE=dem/agent-runner:latest
AGENT_MEMORY_LIMIT=4g
AGENT_CPU_LIMIT=2
DOCKER_HOST=unix:///var/run/docker.sock
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=dem
