###############################################################################
# DEM (plane-swe-agents) configuration
# Copy to .env and fill in. Never commit .env. See README + docs/ for details.
###############################################################################

# ── Claude authentication ───────────────────────────────────────────────────
# Set EXACTLY ONE of the next two. The conductor refuses to start with both or
# neither (prevents silent API billing when you meant subscription).
#
# Option A — Claude Pro/Max subscription (personal use):
#   Run `claude setup-token` on a machine with a browser, paste the result.
CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-xxxxxxxxxxxxxxxxxxxxxxxx
#
# Option B — Anthropic API key (teams / production / pay-per-token):
# ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxx

# Models per role. Any valid Claude Code --model value.
CLAUDE_MODEL_ENGINEER=claude-sonnet-4-6
CLAUDE_MODEL_PLANNER=claude-sonnet-4-6
CLAUDE_MODEL_REVIEWER=claude-haiku-4-5
CLAUDE_MODEL_QA=claude-haiku-4-5

# ── Plane ────────────────────────────────────────────────────────────────────
# Self-hosted instance base (Cloud would be https://api.plane.so).
PLANE_BASE_URL=https://plane.eroizzy.com
# Personal Access Token: Plane → Profile Settings → Personal Access Tokens.
PLANE_API_KEY=plane_api_xxxxxxxxxxxxxxxx
# Workspace slug — the segment in your Plane URL: plane.eroizzy.com/<slug>/...
PLANE_WORKSPACE_SLUG=dem
# Webhook secret Plane generates when you point a webhook at
# <CONDUCTOR_PUBLIC_URL>/webhooks/plane . Verifies X-Plane-Signature.
PLANE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxx
# How an epic is recognized: label | type | parentless. CE has no Epic type,
# so use a label named "epic".
PLANE_EPIC_SIGNAL=label
# Plane Agents beta (native bot comments). Default false = REST comments via PAT.
PLANE_AGENTS_ENABLED=false
# PLANE_BOT_TOKEN=bot_xxxxxxxxxxxxxxxx

# ── GitHub ───────────────────────────────────────────────────────────────────
# Which Plane project builds into which repo lives in targets.yml (keyed on
# project_id). Provide ONE machine-account token here that can reach them all.
# Fine-grained PAT scopes: Contents:rw, Pull requests:rw, Metadata:r.
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxx
# Default base branch PRs target (per-repo override in targets.yml).
GITHUB_BASE_BRANCH=main
# Event delivery: webhook (public URL, e.g. dem.eroizzy.com) or poll.
GITHUB_EVENT_MODE=webhook
GITHUB_POLL_INTERVAL_SECONDS=60
# Required when GITHUB_EVENT_MODE=webhook.
GITHUB_WEBHOOK_SECRET=ghwh_xxxxxxxxxxxxxxxx

# ── Conductor service ────────────────────────────────────────────────────────
CONDUCTOR_HOST=0.0.0.0
CONDUCTOR_PORT=8420
# Public base URL — Plane/GitHub webhook targets are built from this.
CONDUCTOR_PUBLIC_URL=https://dem.eroizzy.com
# Job/state store. SQLite by default; Postgres for servers:
#   postgresql+asyncpg://user:pass@db/dem
DATABASE_URL=sqlite+aiosqlite:////data/conductor.db
# Path to the project->repo mapping.
TARGETS_FILE=targets.yml
# Max simultaneous agent containers (subscription limits + RAM).
MAX_CONCURRENT_AGENTS=1
# Hard timeout per agent run before docker kill (minutes).
AGENT_TIMEOUT_MINUTES=30

# ── Agent containers ─────────────────────────────────────────────────────────
AGENT_IMAGE=dem/agent-runner:latest
AGENT_MEMORY_LIMIT=4g
AGENT_CPU_LIMIT=2
# Docker access for the dispatcher: socket path or a socket-proxy URL.
DOCKER_HOST=unix:///var/run/docker.sock

# ── Observability ────────────────────────────────────────────────────────────
OTEL_ENABLED=true
# Point at your existing collector (barad-dur observability stack).
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=dem

# ── Notifications ────────────────────────────────────────────────────────────
# ntfy | slack | webhook | none
NOTIFY_MODE=none
# NOTIFY_NTFY_URL=https://ntfy.sh/my-secret-topic
# NOTIFY_SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx
# NOTIFY_WEBHOOK_URL=https://example.com/hook
